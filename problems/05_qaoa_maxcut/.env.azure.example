# Copy this file to .env.azure.local and fill in real values before any Azure run.
# This file is intentionally manual-gated to prevent accidental cloud submissions.

AZURE_SUBSCRIPTION_ID=CHANGE_ME_SUBSCRIPTION_ID
AZURE_RESOURCE_GROUP=CHANGE_ME_RESOURCE_GROUP
AZURE_QUANTUM_WORKSPACE=CHANGE_ME_WORKSPACE_NAME
AZURE_LOCATION=CHANGE_ME_LOCATION

# Optional overrides used by QAOA Azure submission tooling.
AZURE_QUANTUM_PROVIDER=azure-quantum
AZURE_QUANTUM_TARGET_ID=microsoft.estimator
